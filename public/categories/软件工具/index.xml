      <title>Cursor使用笔记</title>
      <link>https://bluespace.eu.org/post.bak.20260510232724/%E5%B7%A5%E5%85%B7/%E5%AE%9E%E8%B7%B5/cursor%E4%BD%BF%E7%94%A8%E7%AC%94%E8%AE%B0/</link>
