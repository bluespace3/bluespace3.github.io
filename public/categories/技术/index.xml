&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="n">CREATE&lt;/span> &lt;span class="n">TABLE&lt;/span> &lt;span class="nf">emp&lt;/span> &lt;span class="p">(&lt;/span>
